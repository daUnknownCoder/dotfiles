[global]
monitor = 0
follow = mouse
indicate_hidden = no
shrink = no
separator_height = 4
padding = 20
gaps = true
gap_size = 8
horizontal_padding = 20
frame_width = 3
width = 350
height = 100
sort = no
idle_threshold = 120
font = JetBrainsMono Nerd Font 13
line_height = 4
markup = full
format = "<b>%s</b>\n%b"
alignment = left
show_age_threshold = 60
word_wrap = yes
ignore_newline = no
stack_duplicates = false
hide_duplicate_count = yes
show_indicators = no
icon_position = left
max_icon_size = 48
enable_recursive_icon_lookup = true
icon_theme = "breeze-dark, Papirus-Dark"
mouse_left_click = close_current
mouse_middle_click = do_action, close_current
mouse_right_click = close_all
sticky_history = yes
history_length = 20
browser = thorium-browser -new-tab
always_run_script = true
title = Dunst
class = Dunst
corner_radius = 10
origin = top-right
offset = 20x20
progress_bar = true
progress_bar_height = 10
separator_height = 5
text_icon_padding = 0

[urgency_low]
    timeout = 5
    background = "#1A1B2699"
    foreground = "#04ff00"
    frame_color = "#04ff00"

[urgency_normal]
    timeout = 8
    background = "#1A1B2699"
    foreground = "#ffc300"
    frame_color = "#ffc300"

[urgency_critical]
    timeout = 10
    background = "#1A1B2699"
    foreground = "#E32F2F"
    frame_color = "#E32F2F"
