#! /bin/sh

chosen=$(printf "яАС  Power Off\nяАЮ  Restart\nяЖЖ  Suspend\nяЛЬ  Hibernate\nябВ  Log Out\nяАг  Lock" | rofi -dmenu -i -theme-str '@import "power.rasi"')

case "$chosen" in
	"яАС  Power Off") shutdown -h now ;;
	"яАЮ  Restart") reboot ;;
	"яЖЖ  Suspend") systemctl suspend-then-hibernate ;;
	"яЛЬ  Hibernate") systemctl hibernate ;;
	"ябВ  Log Out") bspc quit ;;
	"яАг  Lock") betterlockscreen -u ~/Pictures/nord-scenery-night.png -l ;;
	*) exit 1 ;;
esac
